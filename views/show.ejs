<% layout("/layouts/boilerplate") -%>

<body>
  <div class="row">
    <div class="col-8 offset-3">
      <h3 style="margin: 1.5rem 0">Listing Detials:</h3>
    </div>
    <div class="card col-6 offset-3">
      <img
        src="<%=listing.image %>"
        class="card-img-top show-img"
        alt="Listing Image"
      />
      <div class="card-body show-card-body">
        <h4 class="show-title"><%= listing.title %></h4>
        <p><%= listing.description %></p>
        <p>&#x20B9; <%= listing.price.toLocaleString("en-IN") %></p>
        <p><%= listing.location %>, <%= listing.country %></p>
        <p></p>
      </div>
      <div class="d-flex gap-3">
          <form action="/listings/<%= listing._id %>/edit" method="get">
            <button type="submit" class="btn">Edit</button>
          </form>
          <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
            <button class="btn delete-btn" type="submit">Delete</button>
          </form>
      </div>
    </div>
  </div>
</body>
