<% layout("/layouts/boilerplate") -%>
    <div class="row my-6">
        <div class="col-12 col-lg-6 offset-lg-3 mt-2">
            <div class="card">
                <div class="card-body p-5 pt-4">
                    <h2 class="text-center mb-4">SignUp Form</h2>
                    <form action="/signup" method="post" novalidate class="needs-validation">
                        <div class="mb-3">
                            <label for="username" class="form-lable">Username</label>
                            <input required type="text" name="username" id="username" class="form-control"
                                placeholder="Enter username" />
                            <div class="valid-feedback">username looks good!</div>
                            <div class="invalid-feedback">please enter username</div>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-lable">Email</label>
                            <input required type="email" name="email" id="email" class="form-control"
                                placeholder="Enter email" />
                            <div class="valid-feedback">email looks good!</div>
                            <div class="invalid-feedback">please enter email</div>
                        </div>

                        <div class="mb-4">
                            <label for="password" class="form-lable">Password</label>
                            <input required type="password" name="password" id="password" class="form-control"
                                placeholder="Enter password" />
                            <div class="valid-feedback">password looks good!</div>
                            <div class="invalid-feedback">please enter password</div>
                        </div>

                        
                        <button class="btn btn-dark w-100" type="submit">SignUp</button>
                        <p class="text-center mt-3 small">Already have an account? <a href="/login">Login</a></p>
                    </form>
                </div>
            </div>
        </div>
    </div>