<% layout("/layouts/boilerplate") -%>
    <style>
        .filters {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
        }

        .scroll-wrapper {
            display: flex;
            flex-wrap: nowrap;
            gap: 40px;
            padding-inline: 40px;
            scroll-behavior: smooth;
            scrollbar-width: none;
            overflow-x: auto;
            overflow-y: hidden;
            white-space: nowrap;
        }

        .filter {
            text-align: center;
            opacity: 0.7;
            transition: opacity 0.3s ease, border-bottom 0.4s ease;
            cursor: pointer;
            border-bottom: 2px solid transparent;
            padding-bottom: 10px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

        .filter:hover {
            opacity: 1;
            border-bottom: 2px solid black;
        }

        .carousel-container {
            position: relative;
            display: flex;
            align-items: center;
            width: 80%;
        }

        .arrow-btn {
            position: absolute;
            z-index: 10;
            background-color: #fff;
            color: black;
            border: none;
            cursor: pointer;
            padding: 20px 10px;
            transition: background-color 0.5 ease;
        }

        .arrow-btn:hover {
            background-color: #f7f7f7;
        }

        .left-btn {
            left: 0;
        }

        .right-btn {
            right: 0;
        }

        .tax-toggle {
            border: 1px solid #d5d5d5;
            border-radius: 5px;
            display: inline-flex;
            align-items: center;
            flex-direction: row-reverse;
            gap: 1rem;
            padding: 1.2rem 1.4rem;
            /* width: 20%; */
        }

        .tax-toggle .form-check-input {
            margin: 0;
            /* reset ALL margins, not just margin-top */
            /* float: none; */
            /* flex-shrink: 0; */
            position: relative;
            /* this is the critical missing piece */
        }

        .tax-toggle .form-check-label {
            margin: 0;
            line-height: 1;
        }

        .tax-toggle .form-check-input {
            background-color: #fff;
            border-color: #000;
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='-4 -4 8 8'%3e%3ccircle r='3' fill='%23000'/%3e%3c/svg%3e");
        }

        .tax-toggle .form-check-input:checked {
            background-color: #000;
            border-color: #000;
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='-4 -4 8 8'%3e%3ccircle r='3' fill='%23fff'/%3e%3c/svg%3e");
        }

        .tax-toggle .form-check-input:focus {
            border-color: #000;
            box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.2);
        }

        /* Custom CSS to target your specific class */
        .tax-toggle .form-check-input {
            width: 3rem;
            /* Standard is 2em */
            height: 1.5rem;
            /* Standard is 1em */
        }

        /* Optional: Increase label font size to match */
        .tax-toggle .form-check-label {
            font-size: 1rem;
            margin-left: 0.5rem;
            vertical-align: middle;
        }

        .tax-info {
            display: none;
        }
    </style>

    <div class="filters">
        <div class="carousel-container">
            <button class="arrow-btn left-btn" id="slideLeft">&#10094;</button>
            <div id="scroll-wrapper" class="scroll-wrapper mt-4 mb-3">
                <div class="filter">
                    <i class="fa-solid fa-fire"></i>
                    <p class="small">Trending</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-bed"></i>
                    <p class="small">Rooms</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-building-wheat"></i>
                    <p class="small">Farms</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-umbrella-beach"></i>
                    <p class="small">Beach</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-panorama"></i>
                    <p class="small">Breathtaking</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-archway"></i>
                    <p class="small">Iconic cities</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-ferry"></i>
                    <p class="small">Ferry</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-house-chimney-window"></i>
                    <p class="small">Cabins</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-baseball"></i>
                    <p class="small">Sports</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-water-ladder"></i>
                    <p class="small">Pools</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-person-skiing"></i>
                    <p class="small">Skiing</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-plane-departure"></i>
                    <p class="small">International</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-gamepad"></i>
                    <p class="small">E-sports</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-mountain-sun"></i>
                    <p class="small">Mountains</p>
                </div>
                <div class="filter">
                    <i class="fa-brands fa-fort-awesome"></i>
                    <p class="small">Castles</p>
                </div>
                <div class="filter">
                    <i class="fa-solid fa-campground"></i>
                    <p class="small">Camping</p>
                </div>
            </div>
            <button class="arrow-btn right-btn" id="slideRight">&#10095;</button>
        </div>

        <div class="form-check form-switch tax-toggle">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display Taxes</label>
        </div>
    </div>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
        <% for (let listing of allListings) { %>
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="listing-card col">
                    <img src=" <%=listing.image.url %>" class="listing-card-img-top" alt="..." style="height: 20rem;">
                    <div class="listing-card-img-overlay"></div>
                    <div class="listing-card-body">
                        <h5 class="listing-card-title">
                            <%= listing.title %>
                        </h5>
                        <p>&#x20B9; <%= listing.price.toLocaleString("en-IN") %> / night <i class="tax-info">+18% GST</i></p>
                        <p class="listing-card-text">
                            <%= listing.description %>
                        </p>
                    </div>
                </div>
            </a>
            <% } %>
    </div>